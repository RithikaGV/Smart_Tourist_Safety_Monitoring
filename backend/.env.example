# Server
PORT=5000
ENVIRONMENT=development
CLIENT_ORIGIN=http://localhost:5173

# MongoDB - matches the "SmartTouristDB" seen in your Compass screenshot
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=SmartTouristDB

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080
ADMIN_JWT_SECRET=change_this_too_admin_secret
OFFICER_JWT_SECRET=change_this_too_officer_secret

# Road snapping / routing (OSRM public demo server, no key needed)
# For production, self-host OSRM with the Nilgiri/Tamil Nadu OSM extract - see README.
OSRM_BASE_URL=https://router.project-osrm.org

# Safety score refresh cron (minutes)
SAFETY_SCORE_INTERVAL_MINUTES=30
